SERVICE_NAME=ecommerce-api
APP_PORT=8080
APP_ENV=local
# Primary (writes + fallback reads). Replica URL empty => app uses primary for reads only.
# POSTGRES_URL=postgres://postgres:postgres@localhost:5432/ecommerce?sslmode=disable
# One or more read-replica DSNs (comma-separated). With N>1 replicas, read pool max is split across replicas (e.g. 60 -> 30 each).
# POSTGRES_REPLICA_URL=postgres://postgres:postgres@localhost:5433/ecommerce?sslmode=disable
# POSTGRES_REPLICA_URL=postgres://...@localhost:5433/...,postgres://...@localhost:5434/...
# POSTGRES_POOL_MAX_CONNS=25
# POSTGRES_READ_POOL_MAX_CONNS=60
# GET /products request deadline in milliseconds (helps reduce client-side cancels under heavy load)
# GET_PRODUCTS_TIMEOUT_MS=12000
# Redis TTL for the products list cache; higher TTL reduces DB pressure during heavy GET load.
# PRODUCTS_CACHE_TTL_SECONDS=120
# Redis client pool (fewer waits for a free connection under concurrency).
# REDIS_POOL_SIZE=128
# REDIS_MIN_IDLE_CONNS=32
# Trace sampling 0..1 (lower = less OTLP + span overhead during load tests; 1 = always sample).
# OTEL_TRACE_SAMPLE_RATIO=1
# Linux-only: multiple Go processes behind SO_REUSEPORT (try on multi-core hosts).
# FIBER_PREFORK=true
# Postgres server slot limits (primary + replica). Raise for heavy k6; lower if Docker OOMs.
# POSTGRES_MAX_CONNECTIONS=1200
# POSTGRES_SUPERUSER_RESERVED=10
# Minimum WAL retained on the primary for streaming replicas (reduces "WAL segment already removed").
# POSTGRES_WAL_KEEP_SIZE=2GB
KAFKA_TOPIC=product-events
KAFKA_GROUP_ID=ecommerce-observability
KAFKA_ASYNC_QUEUE_SIZE=16384
KAFKA_ASYNC_WORKERS=2
OTEL_EXPORTER_OTLP_ENDPOINT=tempo:4317
OTEL_EXPORTER_OTLP_INSECURE=true
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
