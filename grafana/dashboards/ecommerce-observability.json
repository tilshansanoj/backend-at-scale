{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "RPS",
      "targets": [
        {
          "expr": "sum(rate(ecommerce_http_requests_total{route=\"/products\"}[1m]))",
          "legendFormat": "products rps",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Latency P50/P95/P99",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(ecommerce_http_request_duration_seconds_bucket{route=\"/products\"}[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(ecommerce_http_request_duration_seconds_bucket{route=\"/products\"}[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(ecommerce_http_request_duration_seconds_bucket{route=\"/products\"}[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 3,
      "title": "Error Rate",
      "targets": [
        {
          "expr": "sum(rate(ecommerce_http_requests_total{route=\"/products\",status=~\"5..|4..\"}[5m])) / clamp_min(sum(rate(ecommerce_http_requests_total{route=\"/products\"}[5m])), 1)",
          "legendFormat": "error rate",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 4,
      "title": "DB Pool Usage",
      "targets": [
        {
          "expr": "ecommerce_db_pool_connections{pool=\"primary\",state=\"acquired\"}",
          "legendFormat": "primary acquired",
          "refId": "A"
        },
        {
          "expr": "ecommerce_db_pool_connections{pool=\"primary\",state=\"idle\"}",
          "legendFormat": "primary idle",
          "refId": "B"
        },
        {
          "expr": "ecommerce_db_pool_connections{pool=\"primary\",state=\"total\"}",
          "legendFormat": "primary total",
          "refId": "C"
        },
        {
          "expr": "ecommerce_db_pool_connections{pool=\"replica\",state=\"acquired\"}",
          "legendFormat": "replica acquired",
          "refId": "D"
        },
        {
          "expr": "ecommerce_db_pool_connections{pool=\"replica\",state=\"idle\"}",
          "legendFormat": "replica idle",
          "refId": "E"
        },
        {
          "expr": "ecommerce_db_pool_connections{pool=\"replica\",state=\"total\"}",
          "legendFormat": "replica total",
          "refId": "F"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 5,
      "title": "Redis Hit/Miss Ratio",
      "targets": [
        {
          "expr": "sum(rate(ecommerce_redis_cache_total{result=\"hit\"}[5m])) / clamp_min(sum(rate(ecommerce_redis_cache_total{result=~\"hit|miss\"}[5m])), 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "id": 6,
      "title": "Kafka Consumer Lag",
      "targets": [
        {
          "expr": "sum by (partition) (ecommerce_kafka_consumer_lag_messages)",
          "legendFormat": "partition {{partition}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["ecommerce", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Ecommerce Observability",
  "uid": "ecommerce-observability",
  "version": 1,
  "weekStart": ""
}
